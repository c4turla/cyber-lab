<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>Submit Feedback</h1>
            <p class="subtitle">Share your thoughts with the admin team</p>
        </header>

        <nav>
            <a href="/">Home</a>
            <a href="/feedback" class="active">Submit Feedback</a>
            <a href="/dashboard">Dashboard</a>
            <a href="/mfa">MFA Login</a>
        </nav>

        <main>
            <section class="card">
                <h2>Feedback Form</h2>
                <p>Submit your feedback. All submissions are reviewed by administrators.</p>

                <form id="feedback-form">
                    <div class="form-group">
                        <label for="feedback">Your Feedback:</label>
                        <textarea id="feedback" name="feedback" rows="6" placeholder="Enter your feedback here..."></textarea>
                    </div>
                    <button type="submit" class="btn">Submit Feedback</button>
                </form>

                <div id="result" style="display:none;"></div>
            </section>
        </main>

        <footer>
            <p>&copy; 2026 Admin Feedback System - Internal Use Only</p>
        </footer>
    </div>

    <script>
        (function() {
            var c = document.cookie.split('; ');
            for (var i = 0; i < c.length; i++) {
                if (c[i].indexOf('adm_sess=') === 0) {
                    var a = document.querySelectorAll('a');
                    for (var j = 0; j < a.length; j++) {
                        if (a[j].getAttribute('href') === '/mfa') { a[j].style.display = 'none'; }
                    }
                    break;
                }
            }
        })();
        document.getElementById('feedback-form').addEventListener('submit', function(e) {
            e.preventDefault();
            var fd = document.getElementById('feedback').value;
            fetch('/api/feedback', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ feedback: fd })
            }).then(function(r) { return r.json(); }).then(function(data) {
                var rd = document.getElementById('result');
                rd.style.display = 'block';
                rd.className = data.success ? 'success-box' : 'error-box';
                rd.innerHTML = data.success ? '<strong>Success:</strong> ' + data.message : '<strong>Error:</strong> ' + (data.error || 'Unknown');
            }).catch(function(e) {
                var rd = document.getElementById('result');
                rd.style.display = 'block';
                rd.className = 'error-box';
                rd.innerHTML = '<strong>Error:</strong> ' + e;
            });
        });
    </script>
</body>
</html>